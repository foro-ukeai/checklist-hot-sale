  "hs_sections": "[{\"id\":\"benchmarks\",\"title\":\"Resultados\",\"badge\":\"badge-benchmark\",\"badgeLabel\":\"benchmark\",\"moment\":\"ambos turnos\",\"items\":[{\"id\":\"b5\",\"text\":\"Comparar transacciones acumuladas vs objetivo (% TR alcanzado)\",\"tag\":\"benchmark\"},{\"id\":\"b1\",\"text\":\"Comparar CR del día con proyección y otros eventos\",\"tag\":\"benchmark\"},{\"id\":\"b2\",\"text\":\"Comparar CPC actual vs proyección y otros eventos (día 2)\",\"tag\":\"benchmark\"},{\"id\":\"b3\",\"text\":\"Revisar % de inversión vs facturación (objetivo % inv/fact)\",\"tag\":\"benchmark\"},{\"id\":\"2xaya8\",\"text\":\"Revisar entregable de CS de competencia para oportunidades\",\"tag\":\"info\"}]},{\"id\":\"performance\",\"title\":\"Performance de campaña\",\"badge\":\"badge-accion\",\"badgeLabel\":\"acción\",\"moment\":\"mañana y tarde\",\"items\":[{\"id\":\"p1\",\"text\":\"Revisar sesiones performance vs objetivo de sesiones\",\"tag\":\"info\"},{\"id\":\"p2\",\"text\":\"Chequear CR performance y CR automation — ¿hay caída en alguno? (día 2)\",\"tag\":\"alerta\"},{\"id\":\"p3\",\"text\":\"Controlar inversión diaria vs ritmo esperado (avance inv %) skill claude\",\"tag\":\"benchmark\"},{\"id\":\"p5\",\"text\":\"¿Alguna plataforma con inversión 0 o fuera de rango? (Meta, Google, MeLi Ads, TikTok)\",\"tag\":\"alerta\"}]},{\"id\":\"banners\",\"title\":\"Banners y creatividades\",\"badge\":\"badge-info\",\"badgeLabel\":\"sitio\",\"moment\":\"desde día 2\",\"dia2plus\":true,\"items\":[{\"id\":\"bn1\",\"text\":\"Verificar que los banners live siguen activos y sin errores visuales\",\"tag\":\"alerta\"},{\"id\":\"bn4\",\"text\":\"Revisar posición de producto destacado en banners vs posición real en sitio\",\"tag\":\"accion\"},{\"id\":\"bn5\",\"text\":\"QA de envíos de mail para sugerencias de ajustes\",\"tag\":\"accion\"}]},{\"id\":\"competencia\",\"title\":\"Monitoreo de competencia\",\"badge\":\"badge-alerta\",\"badgeLabel\":\"alerta\",\"moment\":\"turno mañana\",\"i