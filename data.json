  "hs_sections": "[{\"id\":\"benchmarks\",\"title\":\"Resultados\",\"badge\":\"badge-benchmark\",\"badgeLabel\":\"benchmark\",\"moment\":\"ambos turnos\",\"items\":[{\"id\":\"b5\",\"text\":\"Comparar transacciones acumuladas vs objetivo (% TR alcanzado)\",\"tag\":\"benchmark\"},{\"id\":\"b1\",\"text\":\"Comparar CR del día con proyección y otros eventos\",\"tag\":\"benchmark\"},{\"id\":\"b2\",\"text\":\"Comparar CPC actual vs proyección y otros eventos (día 2)\",\"tag\":\"benchmark\"},{\"id\":\"b3\",\"text\":\"Revisar % de inversión vs facturación (objetivo % inv/fact)\",\"tag\":\"benchmark\"},{\"id\":\"2xaya8\",\"text\":\"Revisar entregable de CS de competencia para oportunidades\",\"tag\":\"info\"}]},{\"id\":\"performance\",\"title\":\"Performance de campaña\",\"badge\":\"badge-accion\",\"badgeLabel\":\"acción\",\"moment\":\"mañana y tarde\",\"items\":[{\"id\":\"p1\",\"text\":\"Revisar sesiones performance vs objetivo de sesiones\",\"tag\":\"info\"},{\"id\":\"p2\",\"text\":\"Chequear CR performance y CR automation — ¿hay caída en alguno? (día 2)\",\"tag\":\"alerta\"},{\"id\":\"p3\",\"text\":\"Controlar inversión diaria vs ritmo esperado (avance inv %) skill claude\",\"tag\":\"benchmark\"},{\"id\":\"p5\",\"text\":\"¿Alguna plataforma con inversión 0 o fuera de rango? (Meta, Google, MeLi Ads, TikTok)\",\"tag\":\"alerta\"}]},{\"id\":\"banners\",\"title\":\"Banners y creatividades\",\"badge\":\"badge-info\",\"badgeLabel\":\"sitio\",\"moment\":\"desde día 2\",\"dia2plus\":true,\"items\":[{\"id\":\"bn1\",\"text\":\"Verificar que los banners live siguen activos y sin errores visuales\",\"tag\":\"alerta\"},{\"id\":\"bn4\",\"text\":\"Revisar posición de producto destacado en banners vs posición real en sitio\",\"tag\":\"accion\"},{\"id\":\"bn5\",\"text\":\"QA de envíos de mail para sugerencias de ajustes\",\"tag\":\"accion\"}]},{\"id\":\"competencia\",\"title\":\"Monitoreo de competencia\",\"badge\":\"badge-alerta\",\"badgeLabel\":\"alerta\",\"moment\":\"turno mañana\",\"items\":[{\"id\":\"c1\",\"text\":\"Revisar pricing competidor clave vs cliente — ¿hay brecha nueva?\",\"tag\":\"alerta\"},{\"id\":\"c2\",\"text\":\"Chequear si competidor movió posición o destacado en Hot Sale\",\"tag\":\"alerta\"},{\"id\":\"c3\",\"text\":\"Monitorear si hay comunicación agresiva de descuento de competidor (redes/email)\",\"tag\":\"alerta\"},{\"id\":\"c4\",\"text\":\"Anotar cualquier movimiento de competencia para bajada al cliente\",\"tag\":\"accion\"}]},{\"id\":\"sitio\",\"title\":\"Revisión del sitio\",\"badge\":\"badge-alerta\",\"badgeLabel\":\"alerta\",\"moment\":\"desde día 2\",\"dia2plus\":true,\"items\":[{\"id\":\"s2\",\"text\":\"Revisar si hay productos sin stock que deberían salir de campaña\",\"tag\":\"alerta\"},{\"id\":\"s3\",\"text\":\"Confirmar que landing pages de evento cargan correctamente\",\"tag\":\"alerta\"},{\"id\":\"ye6i38\",\"text\":\"Chequear orden de productos vs demanda y comunicación\",\"tag\":\"info\"}]},{\"id\":\"acciones\",\"title\":\"Bajada de acciones\",\"badge\":\"badge-accion\",\"badgeLabel\":\"output\",\"moment\":\"cierre de cada turno\",\"items\":[{\"id\":\"a4\",\"text\":\"Comunicar al equipo de ads si hay algún cambio urgente a ejecutar\",\"tag\":\"accion\"},{\"id\":\"a5\",\"text\":\"Documentar aprendizajes del día para el cierre del evento y proximos eventos\",\"tag\":\"info\"},{\"id\":\"n2txlp\",\"text\":\"Comparar promo más comunicada vs más usada por clientes para recomendaciones de sitio o adaptación\",\"tag\":\"info\"}]}]",
